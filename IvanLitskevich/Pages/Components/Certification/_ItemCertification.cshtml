@using IvanLitskevich.Helpers
@model IvanLitskevich.Models.CertificationModel
<div class="row certification-block">
    <div class="col-sm-3 col-md-4 text-center">
        <partial name="_Avatar" model="new IvanLitskevich.Models.Views.AvatarViewModel(Model.AvatarUrl, Model.Period)" />
    </div>
    <div class="col-sm-9 col-md-8 justify-content-start">
        <h5>@Model.Title</h5>
        <p>@Model.Organization</p>
        @if (!String.IsNullOrWhiteSpace(Model.Text))
        {
            <p class="">@Html.BuildMarkdown(@Model.Text)</p>
        }
        <partial name="_Certificate" model="Model.Certificate" />
    </div>
</div>